{
  "manifest_version": 3,
  "name": "SteamCartSelector",
  "version": "1.0.0",
  "description": "Adiciona checkboxes no carrinho da Steam para escolher quais itens levar na compra, sem precisar comprar o carrinho inteiro.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://store.steampowered.com/cart*",
        "https://checkout.steampowered.com/*"
      ],
      "js": ["steamcart.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "SteamCartSelector",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://store.steampowered.com/*",
    "https://checkout.steampowered.com/*"
  ]
}
